ANTHROPIC_API_KEY=

# Gmail API
# Step 1 — fill in GMAIL_SENDER, GMAIL_CLIENT_ID, GMAIL_CLIENT_SECRET:
#   console.cloud.google.com → APIs & Services → Credentials
#   → Create Credentials → OAuth client ID → Desktop app
#   Client ID and Client Secret are shown there; paste them below.
GMAIL_SENDER=you@gmail.com
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Step 2 — run:  python setup_gmail_oauth.py
#   That script opens a browser, you authorize the app, and it writes
#   GMAIL_REFRESH_TOKEN here automatically. Do not fill it in by hand.
GMAIL_REFRESH_TOKEN=

EMAIL_FROM_NAME=Carvana Tracker
